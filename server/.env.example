# Server Configuration
PORT=5001
NODE_ENV=development
DEBUG=false

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/liedetector?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# Client Configuration (Update for production)
# For localhost: http://localhost:5173
# For Vercel: https://your-frontend-domain.vercel.app
CLIENT_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here

# Email Service (Gmail with App Password)
# Generate app password at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password_here

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_key_here
RAZORPAY_KEY_SECRET=rzp_test_secret_here
RAZORPAY_WEBHOOK_SECRET=webhook_secret_here

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
